  "issues": {
    "delivery_not_ready": {
      "title": "Datenlieferung für {vehicle} noch nicht bereit",
      "description": "Das EU-Data-Act-Portal liefert für dieses Fahrzeug noch keine Datensätze (HTTP 400). Wenn die kontinuierliche 15-Minuten-Anfrage gerade erst erstellt wurde, kann die Aktivierung einige Stunden dauern.\n\nPortal öffnen ({portal_url}) und Abo prüfen. Home Assistant versucht es alle {retry_minutes} Minute(n) erneut. Kein Zugangsdaten-Problem."
    },
    "waiting_for_portal_data": {
      "title": "Warte auf ersten Datensatz für {vehicle}",
      "description": "Anmeldung erfolgreich, aber noch kein Fahrzeugdatensatz angekommen. Auf dem Portal ({portal_url}) prüfen: kontinuierliche 15-Minuten-Anfrage aktiv, Fahrzeug unter Data clusters verknüpft, Auto kürzlich online.\n\nErste Daten oft innerhalb von 15–60 Minuten. Home Assistant versucht es alle {retry_minutes} Minute(n) erneut."
    },
    "empty_snapshots": {
      "title": "Nur leere Schnappschüsse für {vehicle}",
      "description": "Portal-Abo aktiv, bisher nur leere Schnappschüsse ({empty_count} × _no_content_found). Auto aktivieren (fahren, Zündung oder App), damit Telemetrie hochgeladen wird.\n\nHome Assistant versucht es alle {retry_minutes} Minute(n) erneut. Portal: {portal_url}"
    },
    "subscription_expiring_soon": {
      "title": "Portal-Abo läuft bald ab für {vehicle}",
      "description": "Das EU-Data-Act-Portal-Abo läuft voraussichtlich in {days_until} Tag(en) ab. Die kontinuierliche Datenanfrage muss im Portal verlängert werden, sonst kommen keine Datensätze mehr.\n\nPortal öffnen ({portal_url}) und das Abo vor Ablauf erneuern."
    },
    "stale_snapshot": {
      "title": "Keine aktuellen Fahrzeugdaten für {vehicle}",
      "description": "Der letzte echte Fahrzeugschnappschuss ist etwa {hours_since} Stunde(n) alt ({minutes_since} Minuten). Das Auto ist möglicherweise offline oder das Portal liefert keine neuen Datensätze.\n\nAuto aktivieren (fahren, Zündung oder App) und die kontinuierliche Anfrage im Portal ({portal_url}) prüfen."
    }
  },
