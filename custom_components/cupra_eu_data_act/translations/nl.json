  "exceptions": {
    "waiting_for_portal_data": {
      "message": "Aanmelding geslaagd — wachten op de eerste voertuiggegevens van het EU Data Act-portaal. Dit is normaal direct na de installatie en is geen aanmeldingsfout.\n\nControleer op het portaal ({portal_url}):\n• Een continue gegevensaanvraag van 15 minuten is actief voor dit voertuig\n• Het voertuig is gekoppeld onder Data clusters → Vehicle overview\n• De auto was recent online (contact aan of mobiele app)\n\nEchte gegevens komen vaak binnen 15–60 minuten, soms pas enkele uren na het activeren van de aanvraag. Lege _no_content_found-momentopnames zijn normaal wanneer de auto in een venster van 15 minuten geen telemetrie heeft verzonden; ze worden automatisch overgeslagen.\n\nHome Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw. Je hoeft de integratie niet te verwijderen en opnieuw toe te voegen."
    },
    "waiting_for_portal_data_empty_snapshots": {
      "message": "Aanmelding geslaagd — de portaal-aanvraag is actief, maar tot nu toe zijn alleen lege momentopnames ontvangen ({empty_count} × _no_content_found). Het voertuig heeft in die vensters van 15 minuten nog geen telemetrie verzonden.\n\nDit is geen Home Assistant- of aanmeldingsfout. Controleer op het portaal ({portal_url}) of de continue 15-minuten-aanvraag voor dit VIN is ingeschakeld en activeer de auto (rijden, contact of open de mobiele app) zodat deze gegevens kan uploaden.\n\nHet volgende interval kan echte waarden bevatten. Home Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw — verwijder de integratie niet."
    },
    "delivery_not_ready": {
      "message": "Aanmelding geslaagd — gegevenslevering is nog niet gereed (HTTP 400). Als je de continue 15-minuten-aanvraag op het portaal ({portal_url}) net hebt aangemaakt, kan het backend enkele uren duren voordat ZIP-bestanden worden geleverd.\n\nHome Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw. Dit is geen probleem met inloggegevens."
    },
    "config_entry_not_found": {
      "message": "Geen VW Group EU Data Act-configuratie gevonden voor het geselecteerde voertuig."
    },
    "no_config_entries": {
      "message": "Er zijn geen VW Group EU Data Act-voertuigen geconfigureerd."
    },
    "no_loaded_entries": {
      "message": "De integratie voor het geselecteerde voertuig is niet geladen."
    }
  },
  "services": {
    "refresh_now": {
      "name": "Nu vernieuwen",
      "description": "Vraag het EU Data Act-portaal direct op naar een nieuwe dataset, zonder te wachten op de volgende geplande poll.",
      "fields": {
        "config_entry": {
          "name": "Voertuig",
