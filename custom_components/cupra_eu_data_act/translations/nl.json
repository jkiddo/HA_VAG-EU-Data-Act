        }
      }
    }
  },
  "issues": {
    "delivery_not_ready": {
      "title": "Gegevenslevering nog niet gereed voor {vehicle}",
      "description": "Het EU Data Act-portaal levert nog geen datasets voor dit voertuig (HTTP 400). Als je de continue 15-minuten-aanvraag net hebt aangemaakt, kan activering enkele uren duren.\n\nOpen het portaal ({portal_url}) en controleer het abonnement. Home Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw. Geen inlogprobleem."
    },
    "waiting_for_portal_data": {
      "title": "Wachten op eerste dataset voor {vehicle}",
      "description": "Aanmelding geslaagd maar nog geen dataset ontvangen. Controleer op het portaal ({portal_url}) of een continue 15-minuten-aanvraag actief is, het voertuig gekoppeld is onder Data clusters en recent online was.\n\nEerste gegevens komen vaak binnen 15–60 minuten. Home Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw."
    },
    "empty_snapshots": {
      "title": "Alleen lege momentopnames voor {vehicle}",
      "description": "Portaal-abonnement is actief maar tot nu toe alleen lege momentopnames ontvangen ({empty_count} × _no_content_found). Activeer de auto (rijden, contact of app) om telemetrie te uploaden.\n\nHome Assistant probeert het elke {retry_minutes} minuut/minuten opnieuw. Portaal: {portal_url}"
    },
    "listing_failed": {
      "title": "Kan datasets niet opvragen voor {vehicle}",
      "description": "Home Assistant kon geen datasets op het EU Data Act-portaal ({portal_url}) opvragen — meestal een tijdelijke storing (HTTP 5xx), geen inlog- of abonnementsprobleem.\n\nDe laatst bekende voertuigwaarden blijven behouden. Herhaalde fouten vertragen automatisch de pogingen (5 → 15 → 30 minuten). Volgende poging over ongeveer {retry_minutes} minuut/minuten."
    },
    "subscription_expiring_soon": {
      "title": "Portaalabonnement verloopt binnenkort voor {vehicle}",
      "description": "Het EU Data Act-portaalabonnement verloopt naar schatting over {days_until} dag(en). Het continue dataverzoek moet op het portaal worden verlengd, anders stoppen de datasets.\n\nOpen het portaal ({portal_url}) en verleng het abonnement voordat het verloopt."
    },
    "stale_snapshot": {
      "title": "Geen recente voertuiggegevens voor {vehicle}",
      "description": "De laatste echte voertuigmomentopname is ongeveer {hours_since} uur oud ({minutes_since} minuten). De auto is mogelijk offline of het portaal levert geen nieuwe datasets meer.\n\nActiveer de auto (rijden, contact of app) en controleer of het continue verzoek actief is op het portaal ({portal_url})."
    }
  },
