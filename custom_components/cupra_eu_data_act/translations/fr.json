  "exceptions": {
    "waiting_for_portal_data": {
      "message": "Connexion réussie — en attente de la première livraison de données du véhicule depuis le portail EU Data Act. C'est normal juste après la configuration et ce n'est pas une erreur de connexion.\n\nSur le portail ({portal_url}), veuillez vérifier :\n• Une demande de données continue de 15 minutes est active pour ce véhicule\n• Le véhicule est lié sous Data clusters → Vehicle overview\n• La voiture a été en ligne récemment (contact allumage ou application mobile)\n\nLes premières données réelles arrivent souvent sous 15 à 60 minutes, parfois quelques heures après l'activation de la demande. Les instantanés vides _no_content_found sont normaux lorsque la voiture n'a envoyé aucune télémétrie dans une fenêtre de 15 minutes ; ils sont ignorés automatiquement.\n\nHome Assistant réessaie toutes les {retry_minutes} minute(s). Il n'est pas nécessaire de supprimer et de réajouter l'intégration."
    },
    "waiting_for_portal_data_empty_snapshots": {
      "message": "Connexion réussie — l'abonnement au portail est actif, mais seuls des instantanés vides ont été reçus jusqu'à présent ({empty_count} × _no_content_found). Le véhicule n'a encore envoyé aucune télémétrie dans ces fenêtres de 15 minutes.\n\nCe n'est pas une erreur Home Assistant ni de connexion. Sur le portail ({portal_url}), confirmez que la demande continue de 15 minutes est activée pour ce VIN et réveillez la voiture (conduire, contact allumé ou ouvrir l'application mobile) pour qu'elle puisse envoyer des données.\n\nLe prochain intervalle peut contenir de vraies valeurs. Home Assistant réessaie toutes les {retry_minutes} minute(s) — inutile de supprimer l'intégration."
    },
    "delivery_not_ready": {
      "message": "Connexion réussie — la livraison des données n'est pas encore prête (HTTP 400). Si vous venez de créer la demande continue de 15 minutes sur le portail ({portal_url}), le backend peut mettre quelques heures avant de commencer à livrer des fichiers ZIP.\n\nHome Assistant réessaie toutes les {retry_minutes} minute(s). Ce n'est pas un problème d'identifiants."
    },
    "config_entry_not_found": {
      "message": "Aucune entrée VW Group EU Data Act ne correspond au véhicule sélectionné."
    },
    "no_config_entries": {
      "message": "Aucun véhicule VW Group EU Data Act n'est configuré."
    },
    "no_loaded_entries": {
      "message": "L'intégration du véhicule sélectionné n'est pas chargée."
    }
  },
  "services": {
    "refresh_now": {
      "name": "Actualiser maintenant",
      "description": "Interroger immédiatement le portail EU Data Act pour un nouveau jeu de données, sans attendre le prochain cycle planifié.",
      "fields": {
        "config_entry": {
          "name": "Véhicule",
          "description": "Véhicule à actualiser. Laisser vide pour actualiser tous les véhicules configurés."
        }
      }
    }
  },
  "issues": {
    "delivery_not_ready": {
      "title": "Livraison des données pas encore prête pour {vehicle}",
      "description": "Le portail EU Data Act n'a pas encore commencé à livrer des jeux de données pour ce véhicule (HTTP 400). Si vous venez de créer la demande continue de 15 minutes, l'activation peut prendre quelques heures.\n\nOuvrez le portail ({portal_url}) et vérifiez l'abonnement. Home Assistant réessaie toutes les {retry_minutes} minute(s). Ce n'est pas un problème d'identifiants."
    },
    "waiting_for_portal_data": {
      "title": "En attente du premier jeu de données pour {vehicle}",
      "description": "Connexion réussie mais aucun jeu de données reçu. Sur le portail ({portal_url}), vérifiez qu'une demande continue de 15 minutes est active, que le véhicule est lié sous Data clusters et qu'il a été en ligne récemment.\n\nLes premières données arrivent souvent sous 15 à 60 minutes. Home Assistant réessaie toutes les {retry_minutes} minute(s)."
    },
    "empty_snapshots": {
      "title": "Seulement des instantanés vides pour {vehicle}",
      "description": "L'abonnement au portail est actif mais seuls des instantanés vides ont été reçus ({empty_count} × _no_content_found). Réveillez la voiture (conduire, contact allumé ou application) pour envoyer de la télémétrie.\n\nHome Assistant réessaie toutes les {retry_minutes} minute(s). Portail : {portal_url}"
    },
    "listing_failed": {
      "title": "Impossible de lister les jeux de données pour {vehicle}",
      "description": "Home Assistant n'a pas pu lister les jeux de données sur le portail EU Data Act ({portal_url}) — panne temporaire du portail (HTTP 5xx), pas un problème de connexion ou d'abonnement.\n\nLes dernières valeurs connues sont conservées. Les nouvelles tentatives ralentissent automatiquement (5 → 15 → 30 minutes). Prochaine tentative dans environ {retry_minutes} minute(s)."
    },
    "subscription_expiring_soon": {
      "title": "Abonnement portail bientôt expiré pour {vehicle}",
      "description": "L'abonnement au portail EU Data Act devrait expirer dans {days_until} jour(s). La demande de données continues doit être renouvelée sur le portail, sinon les jeux de données cesseront d'arriver.\n\nOuvrez le portail ({portal_url}) et renouvelez l'abonnement avant son expiration."
    },
    "stale_snapshot": {
      "title": "Pas de données récentes du véhicule pour {vehicle}",
      "description": "Le dernier instantané réel du véhicule date d'environ {hours_since} heure(s) ({minutes_since} minutes). La voiture est peut-être hors ligne ou le portail ne livre plus de nouveaux jeux de données.\n\nRéveillez la voiture (conduire, contact ou application) et vérifiez que la demande continue est active sur le portail ({portal_url})."
    }
  },
