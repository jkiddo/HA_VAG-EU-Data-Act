  "exceptions": {
    "waiting_for_portal_data": {
      "message": "Accesso riuscito — in attesa della prima consegna di dati del veicolo dal portale EU Data Act. È normale subito dopo la configurazione e non è un errore di accesso.\n\nSul portale ({portal_url}), verifica che:\n• Una richiesta dati continua di 15 minuti sia attiva per questo veicolo\n• Il veicolo sia collegato in Data clusters → Vehicle overview\n• L'auto sia stata online di recente (contatto accensione o app mobile)\n\nI primi dati reali arrivano spesso entro 15–60 minuti, a volte alcune ore dopo l'attivazione della richiesta. Gli snapshot vuoti _no_content_found sono normali quando l'auto non ha inviato telemetria in una finestra di 15 minuti; vengono ignorati automaticamente.\n\nHome Assistant riprova ogni {retry_minutes} minuto/i. Non è necessario rimuovere e aggiungere di nuovo l'integrazione."
    },
    "waiting_for_portal_data_empty_snapshots": {
      "message": "Accesso riuscito — la richiesta sul portale è attiva, ma finora sono stati ricevuti solo snapshot vuoti ({empty_count} × _no_content_found). Il veicolo non ha ancora inviato telemetria in quelle finestre di 15 minuti.\n\nNon è un errore di Home Assistant o di accesso. Sul portale ({portal_url}) conferma che la richiesta continua di 15 minuti è attiva per questo VIN e sveglia l'auto (guida, accensione o apri l'app mobile) affinché possa caricare i dati.\n\nIl prossimo intervallo può contenere valori reali. Home Assistant riprova ogni {retry_minutes} minuto/i — non rimuovere l'integrazione."
    },
    "delivery_not_ready": {
      "message": "Accesso riuscito — la consegna dei dati non è ancora pronta (HTTP 400). Se hai appena creato la richiesta continua di 15 minuti sul portale ({portal_url}), il backend può impiegare alcune ore prima di iniziare a consegnare file ZIP.\n\nHome Assistant riprova ogni {retry_minutes} minuto/i. Non è un problema di credenziali."
    },
    "config_entry_not_found": {
      "message": "Nessuna voce VW Group EU Data Act corrisponde al veicolo selezionato."
    },
    "no_config_entries": {
      "message": "Nessun veicolo VW Group EU Data Act è configurato."
    },
    "no_loaded_entries": {
      "message": "L'integrazione del veicolo selezionato non è caricata."
    }
  },
  "services": {
    "refresh_now": {
      "name": "Aggiorna ora",
      "description": "Interroga subito il portale EU Data Act per un nuovo dataset, senza attendere il prossimo ciclo pianificato.",
      "fields": {
        "config_entry": {
          "name": "Veicolo",
          "description": "Veicolo da aggiornare. Lasciare vuoto per aggiornare tutti i veicoli configurati."
        }
      }
    }
  },
  "issues": {
    "delivery_not_ready": {
      "title": "Consegna dati non ancora pronta per {vehicle}",
      "description": "Il portale EU Data Act non ha ancora iniziato a consegnare dataset per questo veicolo (HTTP 400). Se hai appena creato la richiesta continua di 15 minuti, l'attivazione può richiedere alcune ore.\n\nApri il portale ({portal_url}) e verifica l'abbonamento. Home Assistant riprova ogni {retry_minutes} minuto/i. Non è un problema di credenziali."
    },
    "waiting_for_portal_data": {
      "title": "In attesa del primo dataset per {vehicle}",
      "description": "Accesso riuscito ma nessun dataset ricevuto. Sul portale ({portal_url}) verifica che una richiesta continua di 15 minuti sia attiva, il veicolo sia collegato sotto Data clusters e sia stato online di recente.\n\nI primi dati arrivano spesso entro 15–60 minuti. Home Assistant riprova ogni {retry_minutes} minuto/i."
    },
    "empty_snapshots": {
      "title": "Solo snapshot vuoti per {vehicle}",
      "description": "L'abbonamento al portale è attivo ma finora sono stati ricevuti solo snapshot vuoti ({empty_count} × _no_content_found). Sveglia l'auto (guida, accensione o app) per caricare la telemetria.\n\nHome Assistant riprova ogni {retry_minutes} minuto/i. Portale: {portal_url}"
    },
    "listing_failed": {
      "title": "Impossibile elencare i dataset per {vehicle}",
      "description": "Home Assistant non ha potuto elencare i dataset sul portale EU Data Act ({portal_url}) — di solito un'interruzione temporanea del portale (HTTP 5xx), non un problema di accesso o abbonamento.\n\nGli ultimi valori noti del veicolo vengono mantenuti. I tentativi rallentano automaticamente (5 → 15 → 30 minuti). Prossimo tentativo tra circa {retry_minutes} minuto/i."
    },
    "subscription_expiring_soon": {
      "title": "Abbonamento portale in scadenza per {vehicle}",
      "description": "L'abbonamento al portale EU Data Act scadrà tra circa {days_until} giorno/i. La richiesta dati continua va rinnovata sul portale, altrimenti i dataset smetteranno di arrivare.\n\nApri il portale ({portal_url}) e rinnova l'abbonamento prima della scadenza."
    },
    "stale_snapshot": {
      "title": "Nessun dato recente del veicolo per {vehicle}",
      "description": "L'ultimo snapshot reale del veicolo risale a circa {hours_since} ora/e fa ({minutes_since} minuti). L'auto potrebbe essere offline o il portale non sta consegnando nuovi dataset.\n\nAttiva l'auto (guida, accensione o app) e verifica che la richiesta continua sia attiva sul portale ({portal_url})."
    }
  },
