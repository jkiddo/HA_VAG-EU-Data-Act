    },
    "abort": {
      "already_configured": "This vehicle is already configured.",
      "auth": "Authentication failed; please re-add the integration.",
      "reauth_successful": "Re-authentication was successful."
    }
  },
  "exceptions": {
    "waiting_for_portal_data": {
      "message": "Login successful — waiting for the first vehicle dataset from the EU Data Act portal. This is expected right after setup and is not a login error.\n\nOn the portal ({portal_url}), please check:\n• A continuous 15-minute data request is active for this vehicle\n• The vehicle is linked under Data clusters → Vehicle overview\n• The car has been online recently (ignition on or mobile app contact)\n\nFirst real data often arrives within 15–60 minutes, sometimes a few hours after enabling the request. Empty _no_content_found snapshots are normal when the car sent no telemetry in a 15-minute window; they are skipped automatically.\n\nHome Assistant retries every {retry_minutes} minute(s). You do not need to remove and re-add the integration."
    },
    "waiting_for_portal_data_empty_snapshots": {
      "message": "Login successful — the portal subscription is active, but only empty snapshots have been received so far ({empty_count} × _no_content_found). The vehicle sent no telemetry in those 15-minute windows yet.\n\nThis is not a Home Assistant or login error. On the portal ({portal_url}), confirm the continuous 15-minute request is enabled for this VIN and wake the car (drive, ignition, or open the mobile app) so it can upload data.\n\nThe next interval may contain real values. Home Assistant retries every {retry_minutes} minute(s) — no need to remove the integration."
    },
    "delivery_not_ready": {
      "message": "Login successful — data delivery is not ready yet (HTTP 400). If you just created the continuous 15-minute request on the portal ({portal_url}), the backend can take a few hours to start delivering ZIP files.\n\nHome Assistant retries every {retry_minutes} minute(s). This is not a credential problem."
    },
    "config_entry_not_found": {
      "message": "No VW Group EU Data Act config entry matches the selected vehicle."
    },
    "no_config_entries": {
      "message": "No VW Group EU Data Act vehicles are configured."
    },
    "no_loaded_entries": {
      "message": "The selected vehicle integration is not loaded."
    }
  },
  "services": {
    "refresh_now": {
      "name": "Refresh now",
      "description": "Query the EU Data Act portal immediately for a new dataset, without waiting for the next scheduled poll.",
      "fields": {
        "config_entry": {
          "name": "Vehicle",
          "description": "Vehicle to refresh. Leave empty to refresh all configured vehicles."
        }
      }
    }
  },
  "issues": {
    "delivery_not_ready": {
      "title": "Data delivery not ready for {vehicle}",
      "description": "The EU Data Act portal has not started delivering datasets for this vehicle yet (HTTP 400). If you just created the continuous 15-minute request, the backend can take a few hours to activate.\n\nOpen the portal ({portal_url}) and confirm the subscription is active. Home Assistant retries every {retry_minutes} minute(s). This is not a credential problem."
    },
    "waiting_for_portal_data": {
      "title": "Waiting for first dataset for {vehicle}",
      "description": "Login succeeded but no vehicle dataset has arrived yet. On the portal ({portal_url}), confirm a continuous 15-minute data request is active, the vehicle is linked under Data clusters, and the car has been online recently.\n\nFirst data often arrives within 15–60 minutes. Home Assistant retries every {retry_minutes} minute(s)."
    },
    "empty_snapshots": {
      "title": "Only empty snapshots for {vehicle}",
      "description": "The portal subscription is active but only empty snapshots have been received so far ({empty_count} × _no_content_found). Wake the car (drive, ignition, or mobile app) so it can upload telemetry.\n\nHome Assistant retries every {retry_minutes} minute(s). Portal: {portal_url}"
    },
    "subscription_expiring_soon": {
      "title": "Portal subscription expiring soon for {vehicle}",
      "description": "The EU Data Act portal subscription is estimated to expire in {days_until} day(s). Continuous data requests must be renewed on the portal or datasets will stop arriving.\n\nOpen the portal ({portal_url}) and renew the subscription before it lapses."
    },
    "stale_snapshot": {
      "title": "No recent vehicle data for {vehicle}",
      "description": "The last real vehicle snapshot is about {hours_since} hour(s) old ({minutes_since} minutes). The car may be offline or the portal may not be delivering new datasets.\n\nWake the car (drive, ignition, or mobile app) and confirm the continuous request is active on the portal ({portal_url})."
    }
  },
